          "nextOnBlocked": null,
          "approvalRequired": false,
          "artifactsWritten": [
            "research-conclusion"
          ]
        },
        "next-action": {
          "phase": "后续动作",
          "executorAgent": "workflow-orchestrator",
          "successCondition": "已明确推荐的后续入口",
          "failureCondition": "无",
          "nextOnSuccess": {
            "profile": "single.standard",
            "node": "plan"
          },
          "nextOnBlocked": null,
          "approvalRequired": false,
          "artifactsWritten": [
            "recommended-next-step"
          ]
        }
      },
      "legacyCommands": [
        "/ucc-flow-single-research"
      ]
    },
