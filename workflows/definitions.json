{
  "pausePolicies": {
    "auto": [
      "build-failed",
      "typecheck-failed",
      "test-failed",
      "dangerous-change",
      "executor-error",
      "conflict"
    ],
    "balanced": [
      "build-failed",
      "typecheck-failed",
      "test-failed",
      "dangerous-change",
      "executor-error",
      "conflict",
      "db-migration",
      "api-contract",
      "auth-change",
      "mass-rename",
      "config-sensitive",
      "doc-conflict"
    ],
    "strict": [
      "build-failed",
      "typecheck-failed",
      "test-failed",
      "dangerous-change",
      "executor-error",
      "conflict",
      "db-migration",
