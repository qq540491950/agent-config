            "node": "plan"
          },
          "nextOnBlocked": null,
          "approvalRequired": false,
          "artifactsWritten": [
            "scope-summary"
          ]
        },
        "plan": {
          "phase": "实现计划",
          "executorAgent": "planner",
          "successCondition": "已形成最小可执行计划",
          "failureCondition": "无法确认关键路径或依赖",
          "nextOnSuccess": {
            "node": "implement"
          },
          "nextOnBlocked": null,
          "approvalRequired": false,
          "artifactsWritten": [
            "implementation-plan"
          ]
        },
        "implement": {
          "phase": "实施",
          "executorAgent": "tdd-guide",
          "successCondition": "完成最小实现且记录验证范围",
          "failureCondition": "实现被构建错误或依赖阻塞",
          "nextOnSuccess": {
            "node": "review"
          },
          "nextOnBlocked": {
            "node": "review"
          },
          "approvalRequired": false,
          "artifactsWritten": [
            "code-change-summary"
          ]
        },
        "review": {
          "phase": "审查",
          "executorAgent": "code-reviewer",
          "successCondition": "关键问题已关闭或已记录阻塞",
          "failureCondition": "存在未解决的关键问题",
          "nextOnSuccess": {
            "node": "verify"
          },
          "nextOnBlocked": null,
          "approvalRequired": false,
          "artifactsWritten": [
            "review-report"
          ]
        },
        "verify": {
          "phase": "验证",
          "executorAgent": "code-reviewer",
          "successCondition": "验证结果可交付",
          "failureCondition": "关键检查失败",
          "nextOnSuccess": {
            "node": "summary"
          },
          "nextOnBlocked": null,
          "approvalRequired": false,
          "artifactsWritten": [
            "verification-report"
          ]
        },
        "summary": {
          "phase": "交付总结",
          "executorAgent": "workflow-orchestrator",
          "successCondition": "总结变更、验证和剩余风险",
          "failureCondition": "无",
          "nextOnSuccess": null,
          "nextOnBlocked": null,
          "approvalRequired": false,
          "artifactsWritten": [
            "delivery-summary"
          ]
        }
      }
    },
