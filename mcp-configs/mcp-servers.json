{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT_HERE"
      },
      "description": "GitHub 操作 - PRs、Issues、仓库管理"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "跨会话持久记忆存储"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "YOUR_PROJECTS_DIR_HERE"],
      "description": "文件系统操作（模板：请替换为你的项目目录）"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"],
      "description": "实时文档查询 - Vue、Go、Node 等框架的最新文档"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "链式推理 - 复杂问题的逐步分析"
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_KEY_HERE"
      },
      "description": "网页抓取和爬取"
    },
    "exa-web-search": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "YOUR_EXA_API_KEY_HERE"
      },
      "description": "网页搜索和研究"
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com",
      "description": "Vercel 部署和项目管理"
    },
    "docker": {
      "command": "npx",
      "args": ["-y", "@docker/mcp-server-docker"],
      "description": "Docker 容器管理"
    }
  },
  "_interactive": {
    "presets": {
      "basic": ["memory", "filesystem", "context7"],
      "research": ["memory", "filesystem", "context7", "sequential-thinking"],
      "full": [
        "github",
        "memory",
        "filesystem",
        "context7",
        "sequential-thinking",
        "firecrawl",
        "exa-web-search",
        "vercel",
        "docker"
      ]
    },
    "requiredParams": {
      "github": [
        {
          "kind": "env",
          "key": "GITHUB_PERSONAL_ACCESS_TOKEN",
          "label": "GitHub Personal Access Token",
          "required": true
        }
      ],
      "filesystem": [
        {
          "kind": "arg",
          "index": 2,
          "label": "filesystem 可访问目录",
          "default": "$PROJECT_ROOT",
          "required": true
        }
      ],
      "firecrawl": [
        {
          "kind": "env",
          "key": "FIRECRAWL_API_KEY",
          "label": "Firecrawl API Key",
          "required": true
        }
      ],
      "exa-web-search": [
        {
          "kind": "env",
          "key": "EXA_API_KEY",
          "label": "Exa API Key",
          "required": true
        }
      ]
    }
  },
  "_comments": {
    "usage": "copy-config.js 会基于此模板和交互输入生成项目根 .mcp.json",
    "required_inputs": "只有 API Key、目录等必要参数需要输入，其余由向导选择或自动推断",
    "platform": "本地 stdio MCP 会按目标平台自动生成命令包装",
    "settings": "启用的项目级 MCP 会同步写入 .claude/settings.json 的 enabledMcpjsonServers"
  },
  "_installation": {
    "step1": "运行 node scripts/copy-config.js <target> --interactive",
    "step2": "按提示选择 hooks、MCP 和平台",
    "step3": "仅输入必要的 Key 或目录",
    "step4": "重启 Claude Code CLI 或重新进入项目"
  }
}
