{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Cmd",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/hooks/run-with-flags.js pre:cmd:risk-blocker .claude/scripts/hooks/pretool-risk-blocker.js standard,strict"
          }
        ],
        "description": "阻断明显高风险的删除/格式化命令（跨 Bash/PowerShell/Cmd，收紧关键字误报）"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/hooks/run-with-flags.js pre:write:sensitive-check .claude/scripts/hooks/pretool-sensitive-write-check.js standard,strict"
          }
        ],
        "description": "写入前检测常见敏感信息模式并提醒"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/hooks/run-with-flags.js post:write:ts-check .claude/scripts/hooks/posttool-ts-check.js standard,strict"
          }
        ],
        "description": "写入 TS/TSX/Vue 文件后自动运行 tsc --noEmit + ESLint 检查"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/hooks/run-with-flags.js post:write:go-check .claude/scripts/hooks/posttool-go-check.js standard,strict"
          }
        ],
        "description": "写入 .go 文件后自动运行 go vet + gofmt 检查（staticcheck 可选）"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/hooks/run-with-flags.js stop:delivery-reminder .claude/scripts/hooks/stop-delivery-reminder.js standard,strict"
          }
        ],
        "description": "每次响应后给出最小交付检查提醒"
      }
    ]
  }
}
