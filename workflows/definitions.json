      "executionModeDefault": "auto",
      "pausePolicyDefault": "auto",
      "entryNode": "clarify",
      "nodes": {
        "clarify": {
          "phase": "需求澄清",
          "executorAgent": "planner",
          "successCondition": "目标、范围和约束明确",
          "failureCondition": "关键需求缺失或存在冲突",
